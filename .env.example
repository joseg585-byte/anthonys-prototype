# ─────────────────────────────────────────────────────────────────────────
# Anthony's prototype — environment template. Copy to `.env.local`.
#
# The app runs fully WITHOUT any of these set: the menu is seeded locally and
# orders + "86" toggles sync live across browser tabs via BroadcastChannel.
# These vars are only needed to light up the optional Supabase backend.
# ─────────────────────────────────────────────────────────────────────────

# Supabase (optional — production backend). After running supabase-schema.sql:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin Command Center demo passcode (the stub /admin gate). Defaults to
# "anthony78" if unset. Production replaces this gate with Supabase Auth.
NEXT_PUBLIC_ADMIN_PASSCODE=anthony78
